# Docker build context optimization
# Exclude large/sensitive files from Docker build context

# Python cache
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache

# Node.js
node_modules/
npm-debug.log
yarn-error.log

# Virtual environments
venv/
env/
.venv/

# Git
.git/
.gitignore
.gitattributes

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp
.cache/

# OS
.DS_Store
Thumbs.db

# Project-specific
src/data/chroma/
*.db
*.sqlite
*.sqlite3

# Documentation
README.md
*.md
docs/

# Test coverage
.coverage
htmlcov/

# Environment
.env
.env.local
.env.*.local

# WhatsApp Web auth/cache
.wwebjs_auth/
.wwebjs_cache/

# Build artifacts
dist/
build/
*.egg-info/

# Large data files (adjust as needed)
*.zip
*.tar.gz
*.rar

# Large binaries
bin/yt-dlp

# Screenshots/temporary images
image.png
*.png
*.jpg
*.jpeg
