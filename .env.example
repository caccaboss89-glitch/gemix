# =============================================================================
# GemiX — copy to .env and fill every uncommented key.
# Same keys as src/config/env.js (REQUIRED[] + optional exports).
# Commented lines = optional; default applied by env.js if omitted.
# =============================================================================

# --- Core AI (direct xAI API) — required -------------------------------------
GROK_MODEL=

# --- OpenRouter (music via Lyria) — required --------------------------------
OPENROUTER_BASE_URL=
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=
MUSIC_MODEL=
MUSIC_STATS_URL=
MUSIC_WRAP_URL=

# --- xAI media models — required ---------------------------------------------
IMAGE_GEN_MODEL=
VIDEO_GEN_MODEL=

# --- People (prompts / tools) — required -------------------------------------
ADMIN_NAME=
LEGAL_NAME=

# --- Discord — required --------------------------------------------------------
BOT_TOKEN=
GUILD_ID=

# --- Email (Gmail SMTP) — required ---------------------------------------------
BOT_EMAIL=
BOT_PASS=

# --- Music wrap + GitHub — required --------------------------------------------
MUSIC_WRAP_PASSWORD=
GITHUB_TOKEN=
GITHUB_REPO=

# --- Infra URLs — required -----------------------------------------------------
GEMIX_NOTIFY_URL=
GEMIX_PUBLIC_ATTACHMENT_BASE_URL=
GEMIX_TEMP_FILE_PORT=

# --- Feature flags — optional (defaults in env.js) -----------------------------
# XAI_USE_API_KEY=false
# MAINTENANCE_MODE=false
# STARTUP_SYSTEM_CLEANUP=false
# XAI_TTS_ENABLED=false
# XAI_REASONING_REPLAY=true

# --- Paths / sandbox — optional ------------------------------------------------
# BUILD_MODEL=
# (if omitted, env.js uses GROK_MODEL)
# XAI_AUTH_FILE=
# XAI_API_KEY=
# XAI_BASE_URL=https://api.x.ai/v1
# LOG_LEVEL=info
# FFPROBE_PATH=ffprobe
# FFMPEG_PATH=ffmpeg
# GEMIX_SANDBOX_IMAGE=gemix-sandbox:latest
# GEMIX_SANDBOX_NETWORK=gemix_sandbox_net
# GEMIX_SANDBOX_PROXY_HOST=gemix-sandbox-proxy
# GEMIX_SANDBOX_PROXY_PORT=8080
